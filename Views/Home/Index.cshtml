</div>

<script>
    // ── State ─────────────────────────────────────────────────
    let BASE = 'https://localhost:7283';

    // ── Boot ──────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('cfg-url').value = BASE;
        ping();
    });

    // ── Theme ─────────────────────────────────────────────────
    function toggleTheme() {
        const html = document.documentElement;
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        const ico = document.getElementById('themeIco');
        ico.innerHTML = next === 'light'
            ? '<path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>'
            : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
    }

    // ── Nav ───────────────────────────────────────────────────
    function go(id, btn) {
        document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('panel-' + id).classList.add('active');
        btn.classList.add('active');
    }

    // ── Ping ──────────────────────────────────────────────────
    async function ping() {
        const dot = document.getElementById('connDot');
        try {
            const r = await fetch(BASE + '/api/Users', { method: 'GET' });
            dot.className = r.ok ? 'status-dot' : 'status-dot offline';
        } catch {
            dot.className = 'status-dot offline';
        }
    }

    // ── HTTP helper ───────────────────────────────────────────
    async function api(method, path, body) {
        const opts = { method, headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' } };
        if (body !== undefined) opts.body = JSON.stringify(body);
        const t = Date.now();
        const r = await fetch(BASE + path, opts);
        const ms = Date.now() - t;
        const ct = r.headers.get('content-type') || '';
        const data = ct.includes('json') ? await r.json() : await r.text();
        return { ok: r.ok, status: r.status, data, ms };
    }

    function ids(str) {
        return str.split(',').map(s => parseInt(s.trim())).filter(n => !isNaN(n));
    }

    // ── Response helpers ──────────────────────────────────────
    function loading(id) {
        const el = document.getElementById(id);
        el.className = 'res loading show';
        el.innerHTML = `<div class="res-bar"><span class="res-dot"></span>Sending…</div>`;
    }

    function show(id, r) {
        const el = document.getElementById(id);
        const ok = r.ok;
        const label = ok ? r.status + ' OK' : r.status + ' Error';
        const body = typeof r.data === 'object' ? JSON.stringify(r.data, null, 2) : String(r.data);
        el.className = `res ${ok ? 'ok' : 'err'} show`;
        el.innerHTML = `<div class="res-bar"><span class="res-dot"></span>${label}<span class="res-ms">${r.ms}ms</span></div>
            <div class="res-body">${x(body)}</div>`;
    }

    function err(id, msg) {
        const el = document.getElementById(id);
        el.className = 'res err show';
        el.innerHTML = `<div class="res-bar"><span class="res-dot"></span>Network Error</div><div class="res-body">${x(msg)}</div>`;
    }

    function clr(id) {
        const el = document.getElementById(id);
        el.className = 'res';
        el.innerHTML = '';
    }

    function x(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // ── Config ────────────────────────────────────────────────
    function saveConfig() {
        BASE = document.getElementById('cfg-url').value.replace(/\/+$/, '');
        document.getElementById('urlDisplay').textContent = BASE.replace(/https?:\/\//, '');
        show('cfg-res', { ok: true, status: 200, data: 'Base URL saved: ' + BASE, ms: 0 });
        ping();
    }

    async function testConn() {
        BASE = document.getElementById('cfg-url').value.replace(/\/+$/, '');
        loading('cfg-res');
        try {
            const r = await api('GET', '/api/Users');
            show('cfg-res', r);
            document.getElementById('connDot').className = r.ok ? 'status-dot' : 'status-dot offline';
        } catch (e) { err('cfg-res', e.message); document.getElementById('connDot').className = 'status-dot offline'; }
    }

    // ── Quick Create ──────────────────────────────────────────
    async function quickCreate() {
        const userName        = document.getElementById('qc-user').value.trim();
        const taskDescription = document.getElementById('qc-task').value.trim();
        const status          = parseInt(document.getElementById('qc-status').value);
        if (!userName || !taskDescription) { err('qc-res', 'Username and Task Description are both required.'); return; }
        loading('qc-res');
        try { show('qc-res', await api('POST', '/api/Assignment/create', { userName, taskDescription, status })); }
        catch (e) { err('qc-res', e.message); }
    }

    // ── Assign ────────────────────────────────────────────────
    async function assignTasks() {
        const userId = ids(document.getElementById('asgn-uids').value);
        const taskId = ids(document.getElementById('asgn-tids').value);
        if (!userId.length || !taskId.length) { err('asgn-res', 'At least one User ID and one Task ID are required.'); return; }
        loading('asgn-res');
        try { show('asgn-res', await api('POST', '/api/Assignment/assign', { userId, taskId })); }
        catch (e) { err('asgn-res', e.message); }
    }

    // ── Update Status (use-case) ──────────────────────────────
    async function updateStatus() {
        const userId        = parseInt(document.getElementById('us-uid').value);
        const taskId        = parseInt(document.getElementById('us-tid').value);
        const currentStatus = parseInt(document.getElementById('us-status').value);
        if (!userId || !taskId) { err('us-res', 'User ID and Task ID are required.'); return; }
        loading('us-res');
        try { show('us-res', await api('PATCH', '/api/Status', { userId, taskId, currentStatus })); }
        catch (e) { err('us-res', e.message); }
    }

    async function getStatus() {
        const u = document.getElementById('gs-uid').value;
        const t = document.getElementById('gs-tid').value;
        if (!u || !t) { err('gs-res', 'User ID and Task ID are required.'); return; }
        loading('gs-res');
        try { show('gs-res', await api('GET', `/api/Status/${u}/${t}`)); }
        catch (e) { err('gs-res', e.message); }
    }

    // ── All Details ───────────────────────────────────────────
    async function getAllDetails() {
        loading('det-res');
        try {
            const r = await api('GET', '/api/Assignment/details');
            if (r.ok && Array.isArray(r.data)) {
                renderDet(r.data);
                clr('det-res');
            } else {
                show('det-res', r);
            }
        } catch (e) { err('det-res', e.message); }
    }

    function renderDet(data) {
        const wrap = document.getElementById('det-tbl');
        if (!data.length) { wrap.innerHTML = '<div class="empty">No records. Create users, tasks, and assign them first.</div>'; return; }
        const rows = data.map(r => {
            const st  = (r.status === 0 || r.status === 'Pending') ? 'Pending' : 'Completed';
            const cls = st === 'Pending' ? 'badge badge-p' : 'badge badge-c';
            return `<tr><td>${r.userId ?? '—'}</td><td>${x(r.username ?? '—')}</td><td>${r.taskId ?? '—'}</td><td>${x(r.description ?? '—')}</td><td><span class="${cls}">${st}</span></td></tr>`;
        }).join('');
        wrap.innerHTML = `<div class="tbl-wrap"><table>
            <thead><tr><th>User ID</th><th>Username</th><th>Task ID</th><th>Description</th><th>Status</th></tr></thead>
            <tbody>${rows}</tbody>
        </table></div>
        <div style="margin-top:8px;font-size:11px;color:var(--text-muted);font-family:var(--ff-mono);">${data.length} record${data.length !== 1 ? 's' : ''}</div>`;
    }

    // ── Users ─────────────────────────────────────────────────
    async function createUser() {
        const username = document.getElementById('u-name').value.trim();
        if (!username) { err('u-c-res', 'Username is required.'); return; }
        loading('u-c-res');
        try { show('u-c-res', await api('POST', '/api/Users', { username })); }
        catch (e) { err('u-c-res', e.message); }
    }

    async function getAllUsers() {
        try {
            const r = await api('GET', '/api/Users');
            const w = document.getElementById('u-tbl');
            if (!r.ok || !Array.isArray(r.data) || !r.data.length) { w.innerHTML = '<div class="empty">No users found.</div>'; return; }
            w.innerHTML = `<div class="tbl-wrap"><table>
                <thead><tr><th>ID</th><th>Username</th></tr></thead>
                <tbody>${r.data.map(u => `<tr><td>${u.userId}</td><td>${x(u.username)}</td></tr>`).join('')}</tbody>
            </table></div>`;
        } catch (e) { document.getElementById('u-tbl').innerHTML = `<div class="empty">${x(e.message)}</div>`; }
    }

    async function getUserById() {
        const id = document.getElementById('u-id').value;
        if (!id) { err('u-id-res', 'User ID is required.'); return; }
        loading('u-id-res');
        try { show('u-id-res', await api('GET', `/api/Users/${id}`)); }
        catch (e) { err('u-id-res', e.message); }
    }

    // ── Tasks ─────────────────────────────────────────────────
    async function createTask() {
        const description = document.getElementById('t-desc').value.trim();
        if (!description) { err('t-c-res', 'Task description is required.'); return; }
        loading('t-c-res');
        try { show('t-c-res', await api('POST', '/api/Tasks', { description })); }
        catch (e) { err('t-c-res', e.message); }
    }

    async function getAllTasks() {
        try {
            const r = await api('GET', '/api/Tasks');
            const w = document.getElementById('t-tbl');
            if (!r.ok || !Array.isArray(r.data) || !r.data.length) { w.innerHTML = '<div class="empty">No tasks found.</div>'; return; }
            w.innerHTML = `<div class="tbl-wrap"><table>
                <thead><tr><th>ID</th><th>Description</th></tr></thead>
                <tbody>${r.data.map(t => `<tr><td>${t.taskId}</td><td>${x(t.description ?? '')}</td></tr>`).join('')}</tbody>
            </table></div>`;
        } catch (e) { document.getElementById('t-tbl').innerHTML = `<div class="empty">${x(e.message)}</div>`; }
    }

    async function getTaskById() {
        const id = document.getElementById('t-id').value;
        if (!id) { err('t-id-res', 'Task ID is required.'); return; }
        loading('t-id-res');
        try { show('t-id-res', await api('GET', `/api/Tasks/${id}`)); }
        catch (e) { err('t-id-res', e.message); }
    }

    // ── Status sub-module ─────────────────────────────────────
    async function statusPost() {
        const userId = parseInt(document.getElementById('st-uid').value);
        const taskId = parseInt(document.getElementById('st-tid').value);
        if (!userId || !taskId) { err('st-p-res', 'User ID and Task ID are required.'); return; }
        loading('st-p-res');
        try { show('st-p-res', await api('POST', '/api/Status', { userId, taskId, currentStatus: 0 })); }
        catch (e) { err('st-p-res', e.message); }
    }

    async function statusPatch() {
        const userId        = parseInt(document.getElementById('st-u-uid').value);
        const taskId        = parseInt(document.getElementById('st-u-tid').value);
        const currentStatus = parseInt(document.getElementById('st-u-status').value);
        if (!userId || !taskId) { err('st-u-res', 'User ID and Task ID are required.'); return; }
        loading('st-u-res');
        try { show('st-u-res', await api('PATCH', '/api/Status', { userId, taskId, currentStatus })); }
        catch (e) { err('st-u-res', e.message); }
    }

    async function statusGet() {
        const u = document.getElementById('st-g-uid').value;
        const t = document.getElementById('st-g-tid').value;
        if (!u || !t) { err('st-g-res', 'Both IDs are required.'); return; }
        loading('st-g-res');
        try { show('st-g-res', await api('GET', `/api/Status/${u}/${t}`)); }
        catch (e) { err('st-g-res', e.message); }
    }
</script>
</body>
</html>
